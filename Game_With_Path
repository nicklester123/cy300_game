import sys
import pygame
from tower_settings import Settingz
from enemy import Enemy
from tower import Tower
import math

class PVTParts:

    def __init__(self):
        """Initialize the game, and create game resources."""
        pygame.init()
        #Frame Rate
        self.clock = pygame.time.Clock()
#Display Window
        self.screen = pygame.display.set_mode((600, 400))
        pygame.display.set_caption("PVT Parts")

# Grid layout
        self.grid_size = 40 

#background color
        self.bg_color = (100, 200, 100)
        #Acess Settings
        self.settings = Settingz()

        #Full screen mode
        self.screen = pygame.display.set_mode((0, 0), pygame.FULLSCREEN)
        self.settings.screen_width = self.screen.get_rect().width
        self.settings.screen_height = self.screen.get_rect().height

        self.screen = pygame.display.set_mode(
            (self.settings.screen_width, self.settings.screen_height))
        # Path
        self.path = [
    (0, 400),
    (300, 400),
    (300, 200),
    (500, 200),
    (500, 500),
    (300, 500),
    (300, 200),
    (600, 200),
    (600, 600),
    (1200, 600)
]
        
        
        #Towers
        self.towers = []
        self.towers.append(Tower(400,300))

        #Enemies
        self.enemy = Enemy(self.path)
        self.hole_pos = self.path[-1]  # last point in path
        self.game_over = False

        self.enemies = [self.enemy]

# Enemy
        self.enemy = Enemy(self.path)
    
    def run_game(self):
        """Start the main loop for the game."""
        while True:
            self._check_events()

            if not self.game_over:
               self.enemy.update()
  

            for tower in self.towers:
                tower.update(self.enemies)

            self._update_screen()

            # # Watch for keyboard and mouse events.
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    sys.exit()
                #Frame rate
            self.clock.tick(60)
             #BG Color
            pygame.display.flip()

            self.enemy.update()
            # check if enemy reached end
            if self.enemy.index >= len(self.path) - 1:
                self.game_over = True


    def _check_events(self):
        """Respond to keypresses and mouse events."""
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                sys.exit()
            elif event.type == pygame.KEYDOWN:
                self._check_keydown_events(event)
            elif event.type == pygame.KEYUP:
                self._check_keyup_events(event)
            elif event.type == pygame.MOUSEBUTTONDOWN:
                mouse_x, mouse_y = pygame.mouse.get_pos()

                grid_x = (mouse_x // self.grid_size) * self.grid_size
                grid_y = (mouse_y // self.grid_size) * self.grid_size

                if not self.is_on_path(grid_x, grid_y) and not self.is_occupied(grid_x, grid_y):
                    self.towers.append(Tower(grid_x, grid_y))
                
    def _update_screen(self):
        """Update images on the screen, and flip to the new screen."""
        self.screen.fill(self.bg_color)

    # draw path
        pygame.draw.lines(self.screen, (150, 75, 0), False, self.path, 10)

    # draw enemy
        self.enemy.draw(self.screen)

        self.screen.fill(self.bg_color)

        pygame.draw.lines(self.screen, (150, 75, 0), False, self.path, 10)
        pygame.draw.circle(self.screen, (0, 0, 0), self.hole_pos, 20)

        self.enemy.draw(self.screen)

    # Game over visual

        if self.game_over:
           font = pygame.font.SysFont(None, 80)
           text = font.render("GAME OVER", True, (255, 0, 0))
           rect = text.get_rect(center=(self.settings.screen_width // 2,
                                     self.settings.screen_height // 2))
           self.screen.blit(text, rect)

    # draw tower
        for tower in self.towers:
            tower.draw(self.screen)

        for x in range(0, self.settings.screen_width, self.grid_size):
            pygame.draw.line(self.screen, (200, 200, 200), (x, 0), (x, self.settings.screen_height))

        for y in range(0, self.settings.screen_height, self.grid_size):
            pygame.draw.line(self.screen, (200, 200, 200), (0, y), (self.settings.screen_width, y))

    # keep this at bottom (avoids blinking)
        pygame.display.flip()

    def path(self):
        self.path = [
    (0, 400),
    (300, 400),
    (300, 200),
    (700, 200),
    (700, 600),
    (1200, 600)
]
        self.enemy = Enemy(self.path)
        pygame.draw.lines(self.screen, (150, 75, 0), False, self.path, 10)

# Prevents placing on the path
    def is_on_path(self, x, y):
        for point in self.path:
            px, py = point
            if abs(x - px) < self.grid_size and abs(y - py) < self.grid_size:
                return True
        return False


# Prevents stacking towers
    def is_occupied(self, x, y):
        for tower in self.towers:
            if tower.x == x and tower.y == y:
                return True
        return False



if __name__ == '__main__':
    # Make a game instance, and run the game.
       ai = PVTParts()
       ai.run_game()
