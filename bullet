import pygame
import math

class Bullet:
    def __init__(self, x, y, target):
        """Initialize the bullet's starting position, tracking target, 
        movement speed, and offensive power."""
        self.x = x
        self.y = y
        self.target = target
        self.speed = 10
        self.damage = 10 # Adjust this to your liking
        self.alive = True

    def update(self):
        """Calculate the trajectory toward the target, apply damage upon impact,
          and manage the bullet's active state."""
        # If target dies before bullet hits, kill the bullet
        if self.target.health <= 0:
            self.alive = False
            return

        # Move toward target
        dx = self.target.x - self.x
        dy = self.target.y - self.y
        dist = math.hypot(dx, dy)

        if dist < self.speed:
            # --- THE "HIT" MOMENT ---
            self.target.health -= self.damage
            self.alive = False
        else:
            self.x += (dx / dist) * self.speed
            self.y += (dy / dist) * self.speed
        # Inside Bullet.update()
        if self.x < 0 or self.x > 1920 or self.y < 0 or self.y > 1080: 
            # Or your screen width/height
            self.alive = False

    def draw(self, screen):
        """Render the bullet as a small circle at its current coordinates on 
        the game screen."""
        pygame.draw.circle(screen, (0, 0, 0), (int(self.x), int(self.y)), 5)
